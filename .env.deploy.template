# Genie Workbench — Deployment Configuration
# Copy this file to .env.deploy and fill in the values.
# Or run scripts/install.sh for guided setup.

# Required: SQL Warehouse ID for query execution
GENIE_WAREHOUSE_ID=

# Required: Unity Catalog name for GSO optimization tables.
# You must have CREATE SCHEMA permission on this catalog.
# The deploy script will create the schema 'genie_space_optimizer' automatically.
GENIE_CATALOG=

# Optional: Databricks App name (default: genie-workbench)
# GENIE_APP_NAME=genie-workbench

# Optional: Databricks CLI profile (default: DEFAULT)
# GENIE_DEPLOY_PROFILE=DEFAULT

# Optional: LLM serving endpoint (default: databricks-claude-sonnet-4-6)
# GENIE_LLM_MODEL=databricks-claude-sonnet-4-6

# Optional: Lakebase instance name for PostgreSQL persistence
# GENIE_LAKEBASE_INSTANCE=

# Optional: MLflow experiment ID for agent tracing (default: disabled)
# Traces Create Agent tool calls and Fix Agent runs.
# Create an experiment in your workspace and paste the ID here.
# GENIE_MLFLOW_EXPERIMENT_ID=
