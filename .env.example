# Genie Workbench - Local Development Environment
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# .env.local is gitignored and never deployed.

# =============================================================================
# Required
# =============================================================================

# Your Databricks workspace URL
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net

# Databricks personal access token
# Generate one at: Settings > Developer > Access tokens
DATABRICKS_TOKEN=your-pat-token

# =============================================================================
# LLM Model
# =============================================================================
LLM_MODEL=databricks-claude-sonnet-4-5

# =============================================================================
# SQL Warehouse (for benchmark execution)
# =============================================================================
SQL_WAREHOUSE_ID=your-warehouse-id

# =============================================================================
# MLflow Tracing (optional)
# =============================================================================
MLFLOW_EXPERIMENT_ID=
MLFLOW_TRACKING_URI=databricks
MLFLOW_REGISTRY_URI=databricks-uc

# =============================================================================
# Genie Space creation target (optional)
# Must be a workspace path where you have write permission
# =============================================================================
GENIE_TARGET_DIRECTORY=

# =============================================================================
# Lakebase PostgreSQL (optional - falls back to in-memory if not set)
# =============================================================================
LAKEBASE_HOST=
LAKEBASE_PORT=5432
LAKEBASE_DATABASE=genie_workbench
LAKEBASE_USER=postgres
LAKEBASE_PASSWORD=

# =============================================================================
# Local dev auth
# =============================================================================
DEV_USER_EMAIL=your-email@company.com

# =============================================================================
# OAuth Authentication (Alternative to PAT)
# =============================================================================
# If you prefer OAuth over PAT, authenticate via the Databricks CLI:
#   databricks auth login
# Then set this to your profile name:
# DATABRICKS_CONFIG_PROFILE=DEFAULT
